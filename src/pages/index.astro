---
import Layout from "../layouts/Layout.astro";
const base = import.meta.env.BASE_URL;
---

<Layout
	title="Home"
	description="Selezionatori e distributori di birre per l'Horeca"
>
	<section class="hero">
		<div class="container hero-content">
			<h1>
				Scegliamo. Distribuiamo.<br /><span class="highlight"
					>Eccelliamo.</span
				>
			</h1>
			<p>
				Willi Bevande è il partner di fiducia per le migliori attività
				Ho.Re.Ca. Offriamo una selezione curata di birre artigianali,
				speciali e tradizionali, dai birrifici locali fino alle
				etichette internazionali più esclusive.
			</p>
			<div class="actions">
				<a href={`${base}catalogo/`} class="btn btn-primary btn-large"
					>Scopri il Catalogo</a
				>
			</div>
		</div>
		<div class="hero-overlay"></div>
	</section>

	<section class="features container">
		<div class="feature-card">
			<h3>Selezione Curata</h3>
			<p>
				Decine di etichette selezionate con rigore per garantire solo il
				meglio ai vostri clienti.
			</p>
		</div>
		<div class="feature-card">
			<h3>Distribuzione Rapida</h3>
			<p>
				Logistica ottimizzata per il settore Ho.Re.Ca, consegne puntuali
				e affidabili.
			</p>
		</div>
		<div class="feature-card">
			<h3>Consulenza Premium</h3>
			<p>
				Affiancamento nella stesura della carta delle birre e training
				per il personale.
			</p>
		</div>
	</section>

	<section class="service-promo">
		<div class="container promo-content">
			<div class="promo-text">
				<h2>
					Impianti Spina in <span class="highlight"
						>Comodato d'Uso</span
					>
				</h2>
				<p>
					La soluzione completa "chiavi in mano" per servire la birra
					perfetta nel tuo locale. Fornitura, installazione e
					manutenzione gratuite a fronte di un accordo di fornitura.
				</p>
				<a
					href={`${base}servizi/impianti-spina/`}
					class="btn btn-outline">Scopri il Servizio</a
				>
			</div>
		</div>
	</section>
</Layout>

<style lang="scss">
	.hero {
		position: relative;
		padding: 6rem 0;
		min-height: 70vh;
		display: flex;
		align-items: center;
		background-color: #111;
		color: #fff;
		overflow: hidden;

		&::before {
			content: "";
			position: absolute;
			top: 0;
			left: 0;
			right: 0;
			bottom: 0;
			/* Background pattern scuro e premium */
			background: radial-gradient(
				circle at center,
				#2a1a0f 0%,
				#0d0d0d 100%
			);
			z-index: 1;
		}
	}

	.hero-content {
		position: relative;
		z-index: 2;
		max-width: 800px;

		h1 {
			font-size: 4rem;
			line-height: 1.1;
			margin-bottom: 2rem;
			color: #fff;
			font-weight: 800;
			letter-spacing: -1px;

			.highlight {
				color: var(--color-primary);
			}
		}

		p {
			font-size: 1.4rem;
			color: #d0d0d0;
			line-height: 1.6;
			margin-bottom: 3rem;
			max-width: 650px;
		}
	}

	.btn-large {
		padding: 1rem 2.5rem;
		font-size: 1.3rem;
		display: inline-block;
		border-radius: 8px;
		background-color: var(--color-primary);
		color: #fff;
		font-weight: bold;
		text-transform: uppercase;
		letter-spacing: 1px;
		transition: all var(--transition-speed);

		&:hover {
			background-color: var(--color-primary-dark);
			transform: translateY(-3px);
			box-shadow: 0 10px 20px rgba(var(--color-primary), 0.3);
			color: white;
		}
	}

	.features {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
		padding: 5rem 1rem;
		margin-top: -3rem; /* Overlap the hero a bit */
		position: relative;
		z-index: 5;
	}

	.feature-card {
		background: var(--color-bg-alt);
		padding: 2.5rem;
		border-radius: 12px;
		box-shadow: 0 15px 35px rgba(0, 0, 0, 0.05);
		border-top: 4px solid var(--color-primary);
		transition: transform var(--transition-speed);

		h3 {
			font-size: 1.5rem;
			margin-bottom: 1rem;
			color: var(--color-secondary);
		}

		p {
			color: var(--color-text-light);
			font-size: 1.1rem;
		}

		&:hover {
			transform: translateY(-10px);
		}
	}

	.service-promo {
		background-color: var(--color-bg);
		padding: 5rem 0;
		border-top: 1px solid #1a1a1a;
		border-bottom: 1px solid #1a1a1a;

		.promo-content {
			display: flex;
			align-items: center;
			justify-content: center;
			text-align: center;
		}

		.promo-text {
			max-width: 700px;
		}

		h2 {
			font-size: 2.5rem;
			color: var(--color-secondary);
			margin-bottom: 1.5rem;

			.highlight {
				color: var(--color-primary);
			}
		}

		p {
			font-size: 1.2rem;
			color: #b0b0b0;
			margin-bottom: 2rem;
			line-height: 1.6;
		}

		.btn-outline {
			padding: 1rem 2rem;
			font-size: 1.1rem;
			display: inline-block;
			border-radius: 8px;
			background-color: transparent;
			border: 2px solid var(--color-primary);
			color: var(--color-primary);
			font-weight: bold;
			text-transform: uppercase;
			transition: all var(--transition-speed);

			&:hover {
				background-color: var(--color-primary);
				color: #fff;
				transform: translateY(-3px);
			}
		}
	}

	@media (max-width: 768px) {
		.hero {
			padding: 4rem 0;
			min-height: 60vh;
			text-align: center; /* Center align on mobile */

			.hero-content h1 {
				font-size: 2.2rem;
			}
			.hero-content p {
				font-size: 1.05rem;
				margin-left: auto;
				margin-right: auto;
			}

			.btn-large {
				width: 100%;
				max-width: 300px;
			}
		}

		.features {
			padding: 3rem 1rem;
		}

		.service-promo {
			padding: 4rem 1rem;

			h2 {
				font-size: 2rem;
			}
		}
	}
</style>
