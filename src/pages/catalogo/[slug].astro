---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
    const beers = await getCollection("beers");

    return beers.map((beer) => ({
        params: { slug: beer.slug },
        props: { beer },
    }));
}

const { beer } = Astro.props;
const { Content } = await beer.render();

const pageTitle = `${beer.data.title} | Willi Bevande`;

// Coerenzia con il catalogo Svelte
const getBeerImage = (beerData) => {
    const style = beerData.style.toLowerCase();
    const title = beerData.title.toLowerCase();

    if (style.includes('rossa') || style.includes('red') || style.includes('stout') || style.includes('scura') || title.includes('sixtus')) {
      return `${base}images/red_placeholder.png`;
    }
    if (style.includes('dark') || title.includes('stout')) {
      return `${base}images/dark_placeholder.png`;
    }
    // Default to blonde
    return `${base}images/blonde_placeholder.png`;
}
---

<Layout
    title={pageTitle}
    description={beer.data.description}
>
    <div class="container section-padding">
        <div class="back-link">
            <a href={`${base}catalogo/`} id="back-btn">← Torna al Catalogo</a>
        </div>

        <article class="beer-detail">
            <div class="product-layout">
                <!-- Image Section -->
                <div class="product-image">
                    <div class="image-box">
                        <img 
                            src={getBeerImage(beer.data)} 
                            alt={beer.data.title} 
                            class="main-img"
                        />
                    </div>
                </div>

                <!-- Info Section -->
                <div class="product-info">
                    <header>
                        <p class="brand">{beer.data.brand}</p>
                        <h1>{beer.data.title}</h1>
                    </header>

                    <div class="specs-box">
                        <div class="spec-row">
                            <span class="label">Stile</span>
                            <span class="value">{beer.data.style}</span>
                        </div>
                        <div class="spec-row">
                            <span class="label">Colore</span>
                            <span class="value">{beer.data.color}</span>
                        </div>
                        <div class="spec-row">
                            <span class="label">Gradazione</span>
                            <span class="value accent">{beer.data.abv}%</span>
                        </div>
                        <div class="spec-row">
                            <span class="label">Nazione</span>
                            <span class="value">{beer.data.country}</span>
                        </div>
                        <div class="spec-row formats-row">
                            <span class="label">Disponibilità</span>
                            <div class="formats-list">
                                {beer.data.format.map((f) => (
                                    <span class="format-tag">{f}</span>
                                ))}
                            </div>
                        </div>
                    </div>

                    <div class="description-area">
                        <h3>Descrizione</h3>
                        <div class="markdown-content">
                            <Content />
                        </div>
                    </div>

                    <div class="cta-box">
                        <p>Sei un professionista Ho.Re.Ca? Richiedi il listino prezzi riservato.</p>
                        <a href="mailto:ordini@willibevande.it" class="btn-primary">Richiedi Informazioni</a>
                    </div>
                </div>
            </div>
        </article>
    </div>
</Layout>

<script>
    document.addEventListener("astro:page-load", () => {
        const backBtn = document.getElementById("back-btn");
        if (backBtn) {
            backBtn.addEventListener("click", (e) => {
                if (window.history.length > 1 && document.referrer.includes(window.location.host)) {
                    e.preventDefault();
                    window.history.back();
                }
            });
        }
    });
</script>

<style lang="scss">
    .section-padding {
        padding-top: 2rem;
        padding-bottom: 5rem;
    }

    .back-link {
        margin-bottom: 3rem;
        a {
            font-size: 0.9rem;
            font-weight: 600;
            color: #999;
            text-decoration: none;
            transition: color 0.3s ease;
            &:hover {
                color: var(--color-primary);
            }
        }
    }

    .product-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 5rem;
        align-items: start;
    }

    .product-image {
        position: sticky;
        top: 120px;
        
        .image-box {
            background: #fff;
            padding: 0;
            border: 1px solid #f0f0f0;
            display: flex;
            justify-content: center;
            align-items: center;
            aspect-ratio: 1 / 1;
            overflow: hidden;

            img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.5s ease;
            }
            
            &:hover img {
                transform: scale(1.05);
            }
        }
    }

    .product-info {
        header {
            margin-bottom: 3rem;
            
            .brand {
                color: var(--color-primary);
                text-transform: uppercase;
                letter-spacing: 2px;
                font-size: 0.8rem;
                font-weight: 700;
                margin-bottom: 0.5rem;
            }

            h1 {
                font-size: 3rem;
                font-weight: 800;
                color: var(--color-secondary);
                margin: 0;
                line-height: 1.1;
                letter-spacing: -1px;
            }
        }
    }

    .specs-box {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
        margin-bottom: 4rem;
        padding: 2rem 0;
        border-top: 1px solid #f0f0f0;
        border-bottom: 1px solid #f0f0f0;

        .spec-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            
            &.formats-row {
                align-items: flex-start;
                flex-direction: column;
                gap: 1rem;
            }

            .label {
                font-size: 0.75rem;
                color: #aaa;
                text-transform: uppercase;
                letter-spacing: 1px;
                font-weight: 700;
            }

            .value {
                font-size: 1.1rem;
                font-weight: 600;
                color: #333;

                &.accent {
                    color: var(--color-primary-dark);
                    font-size: 1.4rem;
                    font-weight: 800;
                }
            }
        }
    }

    .formats-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;

        .format-tag {
            font-size: 0.8rem;
            font-weight: 600;
            color: #666;
            background: #f9f9f9;
            padding: 0.4rem 0.8rem;
            border: 1px solid #eee;
        }
    }

    .description-area {
        margin-bottom: 4rem;
        
        h3 {
            font-size: 1.2rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--color-secondary);
            margin-bottom: 1.5rem;
            font-weight: 800;
        }

        .markdown-content {
            font-size: 1.1rem;
            line-height: 1.7;
            color: #555;
            
            :global(p) { margin-bottom: 1.5rem; }
            :global(strong) { color: #222; font-weight: 700; }
        }
    }

    .cta-box {
        background: #fafafa;
        padding: 2.5rem;
        border-radius: 0;
        border: 1px solid #f0f0f0;
        text-align: center;

        p {
            font-weight: 600;
            color: #666;
            margin-bottom: 1.5rem;
            font-size: 1rem;
        }

        .btn-primary {
            display: inline-block;
            background: var(--color-primary);
            color: white;
            padding: 1rem 2rem;
            text-decoration: none;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
            
            &:hover {
                background: var(--color-primary-dark);
                transform: translateY(-2px);
            }
        }
    }

    @media (max-width: 900px) {
        .product-layout {
            grid-template-columns: 1fr;
            gap: 3rem;
        }

        .product-image {
            position: static;
        }

        .product-info header h1 {
            font-size: 2.2rem;
        }
        
        .specs-box .spec-row .value.accent {
            font-size: 1.2rem;
        }
    }
</style>
