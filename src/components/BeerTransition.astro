---
---
<div id="beer-transition-container" class="beer-transition-container" aria-hidden="true">
    <div class="beer-liquid">
        <!-- Foam Line -->
        <svg class="beer-wave foam" viewBox="0 0 1200 120" preserveAspectRatio="none">
            <path d="M0,60 C150,110 350,10 500,60 C650,110 850,10 1000,60 C1150,110 1350,10 1500,60 L1500,120 L0,120 Z" fill="#ffffff" fill-opacity="0.4"></path>
        </svg>
        <svg class="beer-wave" viewBox="0 0 1200 120" preserveAspectRatio="none">
            <path d="M0,60 C150,110 350,10 500,60 C650,110 850,10 1000,60 C1150,110 1350,10 1500,60 L1500,120 L0,120 Z" fill="url(#beer-grad)"></path>
            <defs>
                <linearGradient id="beer-grad" x1="0%" y1="0%" x2="0%" y2="100%">
                    <stop offset="0%" style="stop-color:#ffb142;stop-opacity:1" />
                    <stop offset="100%" style="stop-color:#f39c12;stop-opacity:1" />
                </linearGradient>
            </defs>
        </svg>
        <div class="beer-fill"></div>
    </div>
</div>

<style lang="scss">
    .beer-transition-container {
        position: fixed;
        inset: 0;
        z-index: 10000; /* Above everything */
        pointer-events: none;
        display: none;
        overflow: hidden;

        &.active {
            display: block;
        }
    }

    .beer-liquid {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 120vh;
        transform: translateY(100%);
        background: #f39c12;
        display: flex;
        flex-direction: column;
    }

    .beer-wave {
        position: absolute;
        top: -90px;
        left: 0;
        width: 200%;
        height: 100px;
        flex-shrink: 0;
        animation: wave-move 2s linear infinite;

        &.foam {
            top: -105px;
            animation: wave-move 2.5s linear infinite reverse;
        }
    }

    .beer-fill {
        flex: 1;
        background: linear-gradient(to bottom, #ffb142, #f39c12);
    }

    @keyframes wave-move {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }
</style>

<script>
    import { gsap } from "gsap";

    // Extend Window interface for TypeScript
    declare global {
        interface Window {
            showBeerTransition: () => gsap.core.Tween;
            hideBeerTransition: () => void;
        }
    }

    let isTransitioning = false;

    function initBeerTransition() {
        const container = document.getElementById('beer-transition-container');
        const liquid = container?.querySelector('.beer-liquid');

        if (!container || !liquid) return;

        window.showBeerTransition = () => {
             isTransitioning = true;
             container.classList.add('active');
             return gsap.to(liquid, {
                y: "0%",
                duration: 0.6,
                ease: "power2.in"
            });
        };

        window.hideBeerTransition = () => {
            gsap.to(liquid, {
                y: "-120%",
                duration: 0.8,
                ease: "power2.out",
                onComplete: () => {
                    container.classList.remove('active');
                    gsap.set(liquid, { y: "100%" });
                    isTransitioning = false;
                }
            });
        };
    }

    // Initialize on load and re-initialize on Astro page loads
    initBeerTransition();

    document.addEventListener('astro:before-preparation', (ev) => {
        const originalLoader = ev.loader;
        ev.loader = async () => {
            if (window.showBeerTransition) {
                await window.showBeerTransition();
            }
            await originalLoader();
        };
    });

    document.addEventListener('astro:page-load', () => {
        if (window.hideBeerTransition) {
             setTimeout(() => window.hideBeerTransition(), 50);
        }
    });

    // Fallback for first load
    window.addEventListener('load', () => {
        if (!isTransitioning) {
            const liquid = document.querySelector('.beer-liquid');
            if (liquid) gsap.set(liquid, { y: "100%" });
        }
    });
</script>
