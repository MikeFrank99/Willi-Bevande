---
import { Image } from "astro:assets";
import logo from "../assets/logos/WilliBevande_Logo.svg";
const base = import.meta.env.BASE_URL;
const pathname = new URL(Astro.request.url).pathname;
// Remove leading base if present to normalize currentPath
const currentPath = pathname.startsWith(base)
    ? pathname.slice(base.length)
    : pathname;
---

<header class="main-header">
    <div class="container header-content">
        <div class="logo-section">
            <div class="logo-wrapper">

                <a href={base} class="logo">
                    <Image
                        src={logo}
                        alt="Willi Bevande Logo"
                        width={240}
                        height={240}
                        loading="eager"
                    />
                </a>
            </div>
        </div>

        <nav class="main-nav">
            <ul>
                <li>
                    <a
                        href={`${base}catalogo/`}
                        class={currentPath === "catalogo/" ||
                        currentPath.startsWith("catalogo/")
                            ? "active"
                            : ""}
                    >
                        <span>Catalogo</span>
                    </a>
                </li>
                <li>
                    <a
                        href={`${base}servizi/impianti-spina/`}
                        class={currentPath.includes("impianti-spina")
                            ? "active"
                            : ""}
                    >
                        <span>Impianti Spina</span>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</header>

<style lang="scss">
    .main-header {
        color: var(--color-text);
        width: 100%;
        position: relative;
        z-index: 1000;
        border-bottom: 1px solid rgba(255, 255, 255, 0.15);
        padding: 0;

        .header-content {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 0;
        }

        .logo-section {
            display: flex;
            justify-content: center;
            align-items: center;
            width: 100%;
        }

        .logo-wrapper {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 0;


            .logo {
                position: relative;
                z-index: 2;
                display: block;

                img {
                    height: 240px;
                    width: auto;
                    margin-top: -1rem;
                    margin-bottom: -1rem;
                    transition: transform 0.3s cubic-bezier(0.2, 1, 0.3, 1);
                    display: block;
                }

                &:hover img {
                    transform: scale(1.05);
                }
            }
        }

        .main-nav {
            z-index: 10;

            ul {
                list-style: none;
                margin: 1.5rem 0 0.5rem 0;
                padding: 0;
                display: flex;
                gap: 2rem;
                align-items: center;
            }

            li a {
                color: #ffffff;
                text-decoration: none;
                font-family: var(--font-family-base), sans-serif;
                font-size: 0.95rem;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: 0.12em;
                padding: 0.8rem 2.2rem;
                border: none;
                border-radius: 0px;
                background: var(--color-primary);
                transition: all 0.3s cubic-bezier(0.19, 1, 0.22, 1);
                display: block;
                position: relative;
                transform: skew(-10deg);
                white-space: nowrap;

                span {
                    display: block;
                    transform: skew(10deg);
                    transition: transform 0.3s;
                }

                &:hover {
                    background: #000000;
                    color: white;
                    transform: skew(-10deg) translateY(-2px);
                }

                &.active {
                    background: #000000;
                    color: white;
                    cursor: default;
                }

                &:active:not(.active) {
                    transform: skew(-10deg) translateY(0);
                }
            }
        }
    }

    @media (max-width: 768px) {
        .main-header {
            padding: 0;

            .logo img {
                height: 140px;
                margin-top: 0;
                margin-bottom: -0.5rem;
            }

            .main-nav ul {
                gap: 2rem;
                li a {
                    font-size: 1rem;
                }
            }
        }
    }
</style>
