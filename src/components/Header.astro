---
import { Image } from "astro:assets";
import logo from "../assets/logos/Willi_Logo.svg";
const base = import.meta.env.BASE_URL;
const pathname = new URL(Astro.request.url).pathname;
// Remove leading base if present to normalize currentPath
const currentPath = pathname.startsWith(base)
    ? pathname.slice(base.length)
    : pathname;
---

<header class="main-header">
    <div class="container header-content">
        <div class="logo-section">
            <div class="logo-wrapper">

                <a href={base} class="logo">
                    <Image
                        src={logo}
                        alt="Willi Bevande Logo"
                        width={230}
                        height={160}
                        loading="eager"
                    />
                </a>
            </div>
        </div>

        <nav class="main-nav">
            <ul>
                <li>
                    <a
                        href={`${base}catalogo/`}
                        class={currentPath === "catalogo/" ||
                        currentPath.startsWith("catalogo/")
                            ? "active"
                            : ""}
                    >
                        Catalogo
                    </a>
                </li>
                <li>
                    <a
                        href={`${base}servizi/impianti-spina/`}
                        class={currentPath.includes("impianti-spina")
                            ? "active"
                            : ""}
                    >
                        Impianti Spina
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</header>

<style lang="scss">
    .main-header {
        color: var(--color-text);
        width: 100%;
        position: relative;
        z-index: 1000;
        border-bottom: 1px solid #eee;
        padding: 2rem 0;

        .header-content {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 1.5rem;
        }

        .logo-section {
            display: flex;
            justify-content: center;
            align-items: center;
            width: 100%;
        }

        .logo-wrapper {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 2rem;



            .logo {
                position: relative;
                z-index: 2;
                display: block;

                img {
                    height: 80px;
                    width: auto;
                    transition: transform 0.3s cubic-bezier(0.2, 1, 0.3, 1);
                    display: block;
                }

                &:hover img {
                    transform: scale(1.05);
                }
            }
        }

        .main-nav {
            z-index: 10;

            ul {
                list-style: none;
                margin: 0;
                padding: 0;
                display: flex;
                gap: 3rem;
                align-items: center;
            }

            li a {
                color: #555;
                text-decoration: none;
                font-family: var(--font-family-base), sans-serif;
                font-size: 1.1rem;
                font-weight: 600;
                letter-spacing: -0.2px;
                transition: all 0.2s ease;
                display: block;
                padding: 0.5rem 0;
                position: relative;

                &:hover,
                &.active {
                    color: var(--color-primary);
                }

                &.active:after {
                    content: "";
                    position: absolute;
                    bottom: -2px;
                    left: 0;
                    width: 100%;
                    height: 2px;
                    background: var(--color-primary);
                }
            }
        }
    }

    @media (max-width: 768px) {
        .main-header {
            padding: 1.5rem 0;

            .logo img {
                height: 60px;
            }

            .main-nav ul {
                gap: 2rem;
                li a {
                    font-size: 1rem;
                }
            }
        }
    }
</style>
