---
import { Image } from "astro:assets";
import logo from "../assets/logos/Willi_Logo.svg";
const base = import.meta.env.BASE_URL;
const pathname = new URL(Astro.request.url).pathname;
// Remove leading base if present to normalize currentPath
const currentPath = pathname.startsWith(base) ? pathname.slice(base.length) : pathname;
---

<header class="main-header">
    <div class="container header-content">
        <a href={base} class="logo">
            <Image
                src={logo}
                alt="Willi Bevande Logo"
                width={230}
                height={160}
                loading="eager"
            />
        </a>

        <nav class="main-nav">
            <ul>
                <li>
                    <a href={`${base}catalogo/`} class={(currentPath === 'catalogo/' || currentPath.startsWith('catalogo/')) ? 'active' : ''}>
                        Catalogo
                    </a>
                </li>
                <li>
                    <a href={`${base}servizi/impianti-spina/`} class={currentPath.includes('impianti-spina') ? 'active' : ''}>
                        Impianti Spina
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</header>

<style lang="scss">
    .main-header {
        background-color: #ffffff;
        color: var(--color-text);
        height: 80px;
        position: sticky;
        top: 0;
        z-index: 1000;
        border-bottom: 1px solid #eee;

        .header-content {
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 80px;
        }

        .logo {
            display: flex;
            align-items: center;
            height: 80px;
            flex-shrink: 0;

            img {
                height: 48px; /* Reduced from 60px */
                width: auto;
                transition: transform 0.2s ease;
                display: block;
                pointer-events: none;
            }

            &:hover img {
                transform: scale(1.05);
            }
        }

        .main-nav {
            ul {
                list-style: none;
                margin: 0;
                padding: 0;
                display: flex;
                gap: 2.5rem;
                align-items: center;
            }

            li a {
                color: #555;
                text-decoration: none;
                font-family: var(--font-family-base), sans-serif;
                font-size: 1rem;
                font-weight: 600;
                letter-spacing: -0.2px;
                transition: all 0.2s ease;
                display: block;
                padding: 0.5rem 0;
                position: relative;

                &:hover, &.active {
                    color: var(--color-primary);
                }

                &.active:after {
                    content: '';
                    position: absolute;
                    bottom: -2px;
                    left: 0;
                    width: 100%;
                    height: 2px;
                    background: var(--color-primary);
                }
            }
        }
    }

    @media (max-width: 768px) {
        .main-header {
            height: auto;
            padding: 1rem 0;

            .header-content {
                flex-direction: column;
                gap: 1rem;
                height: auto;
                justify-content: center;
            }

            .logo {
                height: auto;
                img {
                    height: 65px; /* Reduced from 80px */
                }
            }

            .main-nav ul {
                gap: 1.5rem;
                flex-wrap: wrap;
                justify-content: center;

                li a {
                    font-size: 0.95rem;
                }
            }
        }
    }
</style>
